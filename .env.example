# ─────────────────────────────────────────────────────────────────────────────
# Bia'net Platform — Local Development Configuration
#
# Copy this file to .env and fill in the values.
# See CONFIGURATION.md for detailed setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────

PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── PostgreSQL (Replit-managed DB) ──────────────────────────────────────────
#
# To get the real connection string from Replit:
#   1. Open your Replit project
#   2. Go to Tools → Database (or Secrets tab)
#   3. Copy the DATABASE_URL value
#
# Alternatively, connect a local Postgres instance:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/bianet

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Individual PG connection components (all available in Replit Secrets):
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
#
# Generate strong secrets locally:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# On Replit these are stored as environment variables (not secrets).

JWT_SECRET=replace-with-64-byte-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex-string

# ─── CORS ────────────────────────────────────────────────────────────────────
#
# Comma-separated list of allowed origins for the API.
# Set to * for local development (allows all origins).

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Payment Providers (optional — for webhook testing) ──────────────────────
#
# Required only if you are testing payment webhook flows.
# Obtain from the respective provider's developer dashboard.

PAYSTACK_SECRET_KEY=replace-with-your-paystack-secret-key
FLUTTERWAVE_SECRET_KEY=replace-with-your-flutterwave-secret-key

# ─── AI (optional — for crop diagnosis feature) ──────────────────────────────
#
# Plant.id API key for crop disease diagnosis.
# Register at https://plant.id

PLANT_ID_API_KEY=

# ─── Twilio SMS (required for OTP delivery) ────────────────────────────────────
#
# Required for sending OTP verification SMS messages.
# Sign up at https://twilio.com and get your Account SID, Auth Token, and a phone number.
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+234XXXXXXXXXX

# ─── PostGIS ───────────────────────────────────────────────────────────────────
#
# Set to "true" to enable PostGIS-powered geospatial queries (ST_DWithin).
# Requires the PostGIS extension to be installed in your PostgreSQL database.
# When disabled (default), falls back to Haversine bounding-box formula.
#
POSTGIS_ENABLED=false

# ─── Redis (optional — for caching and rate limiting) ──────────────────────────
#
# Connection string for Redis. If not set, in-memory rate limiting is used.
#
# REDIS_URL=redis://localhost:6379

# ─── Upload Directory (optional — for AI diagnostic images) ────────────────────
#
# Directory for uploaded files. Defaults to ./uploads relative to the API server.
#
# UPLOAD_DIR=./uploads

# ─── Session ─────────────────────────────────────────────────────────────────
#
# Used for secure cookie sessions (currently stored in SESSION_SECRET secret).

SESSION_SECRET=replace-with-random-string
